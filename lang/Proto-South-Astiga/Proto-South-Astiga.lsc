# IPA
Class c {l泰, d, j, l, k什, t什, n, n泰, 蕥, m, k, p, 删泰, d史, s泰, s, 删, r, t, g史}
Class v {e, a, u, i藧, e藧, a藧, o, u藧, i, o藧}

v:
	{ai, ei, oi, ui, au, eu} => {e, i, y, y, a, e}
	{a, e, i, o, u} => {o, a, e, a, u}
	then: {o藧, a藧, e藧, a藧, u藧} => {iu, ia, ie, ia, iu}

c:
	j => *
	r => 删
	{删泰, s泰, l泰, n泰} => {a删, as, al, an}
	d史 => d / @c _
	then: {k什, t什, d史, g史, p, t, k} => {t, k, g, b, h, s, j} // _ @c
	then: @c$1 删 => 删 $1 / @v _ @v
	蕥 => w
