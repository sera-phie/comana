# IPA
Class c {m, k, b, l, s, p, t, 蕯, n, 删, z, 伞, 伞, j, 伞史}
Class v {蓻, i藧, e藧, 蓴, u藧, a藧, 蓱, 蓻虄藧, 蓱虄藧, 蓴虄藧, 蓻虄, 蓴虄, 蓱虄}

v:
    {蓻, 蓴, 蓱} {n, m} => {蓻虄, 蓴虄, 蓱虄} * / _ {$, @c}
    {i藧, e藧, a藧, u藧} {n, m} => {蓻虄藧, 蓻虄藧, 蓱虄藧, 蓴虄藧} * / _ {$, @c}

c:
    伞史 => 伞
    {b, d, 伞} => {w, j, h} / @v _ @v
    {a藧, e藧, i藧, u藧} => {蓱藧, 蓻藧, 蓻藧, 蓴藧}
    蕯 => 伞